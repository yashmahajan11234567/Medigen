version: '3.8'

services:
  db:
    image: postgres:15-alpine
    container_name: medigen_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-medigen}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-medigenpass}
      POSTGRES_DB: ${POSTGRES_DB:-medigen}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER"]
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    build:
      context: .
      dockerfile: ./app/Dockerfile
    container_name: medigen_backend
    restart: unless-stopped
    environment:
      MEDIGEN_APP_NAME: ${MEDIGEN_APP_NAME:-MediGen API}
      MEDIGEN_ENVIRONMENT: ${MEDIGEN_ENVIRONMENT:-production}
      MEDIGEN_DEBUG: ${MEDIGEN_DEBUG:-false}
      MEDIGEN_API_V1_PREFIX: ${MEDIGEN_API_V1_PREFIX:-/api/v1}
      MEDIGEN_SECRET_KEY: ${MEDIGEN_SECRET_KEY:-change-this-secret-key}
      MEDIGEN_JWT_ALGORITHM: ${MEDIGEN_JWT_ALGORITHM:-HS256}
      MEDIGEN_ACCESS_TOKEN_EXPIRE_MINUTES: ${MEDIGEN_ACCESS_TOKEN_EXPIRE_MINUTES:-60}
      MEDIGEN_DATABASE_URL: ${MEDIGEN_DATABASE_URL:-postgresql://${POSTGRES_USER:-medigen}:${POSTGRES_PASSWORD:-medigenpass}@db:5432/${POSTGRES_DB:-medigen}}
      MEDIGEN_AUTO_CREATE_TABLES: ${MEDIGEN_AUTO_CREATE_TABLES:-true}
      MEDIGEN_CORS_ORIGINS: ${MEDIGEN_CORS_ORIGINS:-http://localhost:3000}
    depends_on:
      db:
        condition: service_healthy
    ports:
      - "8000:8000"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 15s
      timeout: 3s
      retries: 3

  frontend:
    build:
      context: .
      dockerfile: ./frontend/Dockerfile
      args:
        VITE_API_BASE_URL: http://backend:8000/api/v1
    container_name: medigen_frontend
    restart: unless-stopped
    ports:
      - "80:80"
    # No direct dependence on the backend for startup, but the frontend will need the backend to be available at runtime.
    # We rely on the frontend's ability to handle backend unavailability (show error, retry, etc.)

volumes:
  postgres_data: